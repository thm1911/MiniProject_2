<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.shoppingapp.ui.home.HomeFragment"
        android:label="@string/home_fragment_title"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_homeFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.shoppingapp.ui.login.LoginFragment"
        android:label="@string/login_screen_title"
        tools:layout="@layout/fragment_login" />

    <fragment
        android:id="@+id/productsFragment"
        android:name="com.example.shoppingapp.ProductsFragment"
        android:label="@string/products_screen_title"
        tools:layout="@layout/fragment_products" />

    <fragment
        android:id="@+id/categoriesFragment"
        android:name="com.example.shoppingapp.CategoriesFragment"
        android:label="@string/categories_screen_title"
        tools:layout="@layout/fragment_categories" />

    <fragment
        android:id="@+id/productDetailFragment"
        android:name="com.example.shoppingapp.ProductDetailFragment"
        android:label="@string/product_detail_screen_title"
        tools:layout="@layout/fragment_product_detail" />

</navigation>